# Optional API keys. Leave blank to use urlscan.io free search.
URLSCAN_KEY=
PUBLICWWW_KEY=

# Optional admin login. Leave ADMIN_PASSWORD BLANK to run fully open (local default).
# Set ADMIN_PASSWORD to require Basic-auth for recipe management (create + test recipe);
# running jobs and downloading exports stay open ("run-only") for unauthenticated users.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional Stripe billing (credit packs). Leave STRIPE_SECRET_KEY blank to disable.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_CURRENCY=gbp

# Deployment. LEADVAULT_ENV=prod enforces a strong secret + Secure cookies and disables demo seeding.
LEADVAULT_ENV=dev
LEADVAULT_SECRET=
# Admin login to seed (REQUIRED in prod; defaults to admin@leadvault.local/admin12345 in dev only):
LEADVAULT_ADMIN_EMAIL=
LEADVAULT_ADMIN_PASSWORD=
# Seed the demo buyer (buyer@demo.local). Defaults: on in dev, off in prod.
LEADVAULT_SEED_DEMO_BUYER=
# Override the SQLite path if desired:
LEADVAULT_DB=
